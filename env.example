# ============================================
# BioPath Pro v2 - Environment Variables
# ============================================
# 
# Talimatlar:
# 1. Bu dosyayı ".env" olarak kopyala
# 2. Placeholder değerleri senin gerçek API key'leriyle değiştir
# 3. Vercel'de bu değerleri "Settings → Environment Variables" bölümüne ekle
#
# ============================================

# HUGGING FACE API KEY (AI Bio Generator için)
# Nereden alınır: https://huggingface.co/settings/tokens
# Gerekli: EVET
NEXT_PUBLIC_HF_API_KEY=hf_YOUR_HUGGING_FACE_API_KEY_HERE

# APP URL (Vercel deployment sonrası güncellenecek)
# Vercel otomatik doldurur, el ile değiştirme gerekir
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub API Rate Limit (isteğe bağlı)
# Varsayılan: 30 (herkese açık repolar için)
NEXT_PUBLIC_GITHUB_SEARCH_LIMIT=30

# ============================================
# SUPABASE (Veritabanı - İsteğe Bağlı)
# Nereden alınır: https://supabase.com
# ============================================

# SUPABASE_URL=your_supabase_project_url
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# NOTLAR
# ============================================
#
# 1. HUGGING FACE API KEY NASIL ALINIR?
#    - https://huggingface.co/settings/tokens adresine git
#    - "New token" butonuna tıkla
#    - İsim ver (örneğin: "BioPath Pro")
#    - Token type: "Read"
#    - "Create token" butonuna tıkla
#    - Token'ı kopyala ve NEXT_PUBLIC_HF_API_KEY=hf_XXX olarak yapıştır
#
# 2. VERCEL'DE NASIL AYARLANIR?
#    - Vercel dashboard'a git: https://vercel.com/dashboard
#    - Projeyi seç: biopath-coral
#    - Settings → Environment Variables
#    - Her bir değeri sırayla ekle:
#      * Key: NEXT_PUBLIC_HF_API_KEY
#        Value: hf_YOUR_API_KEY
#      * Key: NEXT_PUBLIC_APP_URL
#        Value: https://biopath-coral.vercel.app
#    - Redeploy et
#
# 3. GITHUB API KEY GEREKLI MI?
#    - Hayır! Herkese açık repolar için gerekli değil
#    - GitHub API'ye doğrudan erişim yapıyoruz
#
# 4. .env.local VE .env.example FARKI
#    - .env.example: Bu dosya (template, GitHub'a push edilir)
#    - .env: Senin gerçek API key'leri (ASLA push etme!)
#    - .gitignore: .env dosyasını GitHub'a yüklemesini engeller
#
# ============================================
