# ============================================
# BioPath Pro — Environment Variables Template
# ============================================
# Bu dosya TEMPLATE'dir. Gerçek key içermez.
# GitHub'a push edilebilir, güvenlidir.
#
# YAPILACAKLAR:
# Vercel Dashboard → Projen → Settings → Environment Variables
# Aşağıdaki key'leri oraya ekle (bu dosyayı değil!)
# ============================================

# ── SUPABASE (ZORUNLU) ──────────────────────
# Nereden alınır:
# 1. https://supabase.com → New Project oluştur
# 2. Project Settings → API → Project URL ve anon key'i kopyala
NEXT_PUBLIC_SUPABASE_URL=https://PROJE_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# ── AI BIO (İSTEĞE BAĞLI) ───────────────────
# Nereden alınır: https://huggingface.co/settings/tokens
NEXT_PUBLIC_HF_API_KEY=hf_BURAYA_HUGGINGFACE_API_KEYIN

# ── UYGULAMA URL ────────────────────────────
NEXT_PUBLIC_APP_URL=https://SENIN_PROJEN.vercel.app
