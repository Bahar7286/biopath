# ====================================
# API KEYS - DOLDURULACAK YERLERİ
# ====================================

# 1. HUGGING FACE API KEY (AI Bio Generator)
# https://huggingface.co/settings/tokens
# Token type: "Read" yeterli
NEXT_PUBLIC_HF_API_KEY=your_hugging_face_api_key_here

# 2. GITHUB API (Public Repos - opsiyonel)
# GitHub API public repos için token zorunlu değil
# Ama rate limit için token kullanabilirsin:
# https://github.com/settings/tokens
NEXT_PUBLIC_GITHUB_TOKEN=your_github_token_here

# 3. SUPABASE (Database - Gelecek sürümler için hazır)
# https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 4. APP URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel'de bu değerleri Vercel Dashboard'da ayarla:
# Settings → Environment Variables
