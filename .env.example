# ============================================
# BioPath Pro — Environment Variables Template
# ============================================
# Bu dosya TEMPLATE'dir. Gerçek key içermez.
# GitHub'a push edilir, güvenlidir.
#
# YAPILACAKLAR:
# 1. Vercel Dashboard → Projen → Settings → Environment Variables
# 2. Aşağıdaki key'leri oraya ekle (bu dosyayı değil!)
# ============================================

# ZORUNLU — AI Bio Generator çalışması için
# Nereden alınır: https://huggingface.co/settings/tokens
# → New token → Read → Oluştur → Kopyala
NEXT_PUBLIC_HF_API_KEY=hf_BURAYA_HUGGINGFACE_API_KEYIN

# Vercel deploy sonrası kendi domain'ini yaz
# Örnek: https://biopath-pro.vercel.app
NEXT_PUBLIC_APP_URL=https://SENIN_PROJEN.vercel.app

# İsteğe bağlı
NEXT_PUBLIC_GITHUB_SEARCH_LIMIT=30

# İleride Supabase ekleyince bunları aç:
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
